{
  "expo": {
    "name": "Time Tracker",
    "slug": "TimeTracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#EEF3FA",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEF3FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jai.timetracker"
    },
    "android": {
      "package": "com.jai.timetracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EEF3FA"
      },
      "permissions": [
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}